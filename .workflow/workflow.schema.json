{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "workflow-orchestrator config",
  "type": "object",
  "required": ["commands", "workflows"],
  "additionalProperties": false,
  "properties": {
    "commands": {
      "type": "object",
      "properties": {
        "test":  { "type": "string", "description": "テスト実行コマンド（例: make test）" },
        "lint":  { "type": "string" },
        "build": { "type": "string" }
      },
      "required": ["test"],
      "additionalProperties": { "type": "string" }
    },
    "workflows": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/workflow" }
    }
  },
  "definitions": {
    "workflow": {
      "type": "object",
      "required": ["name", "steps"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/step" }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id":            { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "name":          { "type": "string" },
        "description":   { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/action" },
          "description": "自動実行するアクション一覧（parallel と同時指定不可）"
        },
        "parallel": {
          "type": "array",
          "items": { "$ref": "#/definitions/sub_step" },
          "description": "並列実行するサブステップ（actions と同時指定不可）"
        },
        "checklist_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$",
          "description": "手動記録を促すキー（manual ステップで使用）"
        },
        "requires": {
          "type": "array",
          "items": { "type": "string" },
          "description": "完了に必要な他ステップの id"
        }
      }
    },
    "sub_step": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/action" }
        },
        "requires": {
          "type": "array",
          "items": { "type": "string" },
          "description": "完了に必要な他サブステップの id（並列ブロック内依存）"
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["run", "agent", "skill", "workflow"]
        }
      },
      "oneOf": [
        { "$ref": "#/definitions/action_run" },
        { "$ref": "#/definitions/action_agent" },
        { "$ref": "#/definitions/action_skill" },
        { "$ref": "#/definitions/action_workflow" }
      ]
    },
    "action_run": {
      "properties": {
        "type":    { "const": "run" },
        "command": { "type": "string", "description": "実行するコマンド（{{commands.test}} 形式のテンプレート使用可）" },
        "gate":    { "type": "boolean", "description": "true のとき実行記録が complete の必須条件になる" }
      },
      "required": ["type", "command"]
    },
    "action_agent": {
      "properties": {
        "type":       { "const": "agent" },
        "prompt":     { "type": "string" },
        "background": { "type": "boolean", "description": "true のとき他のアクションと並列実行してよい" }
      },
      "required": ["type", "prompt"]
    },
    "action_skill": {
      "properties": {
        "type":  { "const": "skill" },
        "skill": { "type": "string" },
        "args":  { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "skill"]
    },
    "action_workflow": {
      "properties": {
        "type":     { "const": "workflow" },
        "workflow": { "type": "string" },
        "inputs":   { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "required": ["type", "workflow"]
    }
  }
}
