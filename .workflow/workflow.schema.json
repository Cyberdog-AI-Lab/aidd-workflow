{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "workflow-orchestrator config",
  "description": "Root config.yml or any import file. All top-level keys are optional in individual files. The fully merged config must define commands.test.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "imports": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional YAML files to merge, relative to .workflow/"
    },
    "commands": {
      "type": "object",
      "description": "Named shell commands. commands.test is required in the merged config.",
      "properties": {
        "test":  { "type": "string", "description": "Test command (required in merged config, e.g. make test)" },
        "lint":  { "type": "string" },
        "build": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "workflows": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/workflow" }
    }
  },
  "definitions": {
    "workflow": {
      "type": "object",
      "required": ["name", "steps"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/step" }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/action" },
          "description": "Actions to run automatically. Mutually exclusive with parallel (checked at runtime)."
        },
        "parallel": {
          "type": "array",
          "items": { "$ref": "#/definitions/sub_step" },
          "description": "Sub-steps to run in parallel. Mutually exclusive with actions (checked at runtime)."
        },
        "requires": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of steps that must complete before this step starts (checked at runtime)."
        },
        "pre_commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Shell commands run automatically when the step becomes InProgress. Supports {{commands.<key>}} interpolation."
        },
        "post_commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Shell commands run as a gate before Complete is allowed. Supports {{commands.<key>}} interpolation."
        },
        "allow_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File path patterns permitted for editing while InProgress (glob or /regex/)."
        },
        "deny": { "$ref": "#/definitions/deny_rules" },
        "guards": {
          "type": "array",
          "items": { "$ref": "#/definitions/guard" },
          "description": "Preconditions that must hold before this step can begin."
        }
      }
    },
    "sub_step": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/action" }
        },
        "requires": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of other sub-steps within the same parallel block that must complete first (checked at runtime)."
        }
      }
    },
    "deny_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "File path patterns forbidden from editing (glob or /regex/)."
        },
        "commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Shell command patterns forbidden from running (substring match)."
        }
      }
    },
    "guard": {
      "type": "object",
      "required": ["step"],
      "additionalProperties": false,
      "properties": {
        "step": {
          "type": "string",
          "description": "ID of a step that must have completed (checked at runtime)."
        },
        "required_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files that must exist before this step can begin (glob or /regex/)."
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["agent", "skill", "workflow"]
        }
      },
      "oneOf": [
        { "$ref": "#/definitions/action_agent" },
        { "$ref": "#/definitions/action_skill" },
        { "$ref": "#/definitions/action_workflow" }
      ]
    },
    "action_agent": {
      "properties": {
        "type":       { "const": "agent" },
        "prompt":     { "type": "string" },
        "background": { "type": "boolean", "description": "When true, may run concurrently with other actions in the same step." }
      },
      "required": ["type", "prompt"]
    },
    "action_skill": {
      "properties": {
        "type":  { "const": "skill" },
        "skill": { "type": "string" },
        "args":  { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "skill"]
    },
    "action_workflow": {
      "properties": {
        "type":     { "const": "workflow" },
        "workflow": { "type": "string" },
        "inputs":   { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "required": ["type", "workflow"]
    }
  }
}
