{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "workflow-orchestrator config",
  "type": "object",
  "required": ["commands", "workflows"],
  "additionalProperties": false,
  "properties": {
    "imports": {
      "type": "array",
      "items": { "type": "string" },
      "description": "追加でロードする YAML ファイルのパス（.workflow/ 相対）"
    },
    "commands": {
      "type": "object",
      "properties": {
        "test":  { "type": "string", "description": "テスト実行コマンド（例: make test）" },
        "lint":  { "type": "string" },
        "build": { "type": "string" }
      },
      "required": ["test"],
      "additionalProperties": { "type": "string" }
    },
    "workflows": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/workflow" }
    }
  },
  "definitions": {
    "workflow": {
      "type": "object",
      "required": ["name", "steps"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/step" }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/action" },
          "description": "自動実行するアクション一覧（parallel と同時指定不可）"
        },
        "parallel": {
          "type": "array",
          "items": { "$ref": "#/definitions/sub_step" },
          "description": "並列実行するサブステップ（actions と同時指定不可）"
        },
        "requires": {
          "type": "array",
          "items": { "type": "string" },
          "description": "完了に必要な他ステップの id"
        },
        "pre_commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "ステップ開始時に自動実行するコマンド"
        },
        "post_commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "ステップ完了前にゲートとして実行するコマンド"
        },
        "allow_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "InProgress 中に編集を許可するファイルパターン（glob または /regex/）"
        },
        "deny": { "$ref": "#/definitions/deny_rules" },
        "guards": {
          "type": "array",
          "items": { "$ref": "#/definitions/guard" },
          "description": "このステップを開始する前に満たすべき条件"
        }
      }
    },
    "sub_step": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
        "name":        { "type": "string" },
        "description": { "type": "string" },
        "actions": {
          "type": "array",
          "items": { "$ref": "#/definitions/action" }
        },
        "requires": {
          "type": "array",
          "items": { "type": "string" },
          "description": "完了に必要な他サブステップの id（並列ブロック内依存）"
        }
      }
    },
    "deny_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "編集を禁止するファイルパターン（glob または /regex/）"
        },
        "commands": {
          "type": "array",
          "items": { "type": "string" },
          "description": "実行を禁止するコマンドパターン（部分一致）"
        }
      }
    },
    "guard": {
      "type": "object",
      "required": ["step"],
      "additionalProperties": false,
      "properties": {
        "step": {
          "type": "string",
          "description": "完了済みである必要があるステップの id"
        },
        "required_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "存在が必要なファイルパターン（glob または /regex/）"
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["agent", "skill", "workflow"]
        }
      },
      "oneOf": [
        { "$ref": "#/definitions/action_agent" },
        { "$ref": "#/definitions/action_skill" },
        { "$ref": "#/definitions/action_workflow" }
      ]
    },
    "action_agent": {
      "properties": {
        "type":       { "const": "agent" },
        "prompt":     { "type": "string" },
        "background": { "type": "boolean", "description": "true のとき他のアクションと並列実行してよい" }
      },
      "required": ["type", "prompt"]
    },
    "action_skill": {
      "properties": {
        "type":  { "const": "skill" },
        "skill": { "type": "string" },
        "args":  { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "skill"]
    },
    "action_workflow": {
      "properties": {
        "type":     { "const": "workflow" },
        "workflow": { "type": "string" },
        "inputs":   { "type": "object", "additionalProperties": { "type": "string" } }
      },
      "required": ["type", "workflow"]
    }
  }
}
