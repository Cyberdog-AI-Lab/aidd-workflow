{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "workflow-runner hook post-edit",
            "type": "command"
          },
          {
            "command": ".claude/hooks/post-edit-rust-checks.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "command": "workflow-runner hook post-edit",
            "type": "command"
          },
          {
            "command": ".claude/hooks/post-edit-rust-checks.sh",
            "type": "command"
          }
        ],
        "matcher": "Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "workflow-runner hook pre-edit",
            "type": "command"
          }
        ],
        "matcher": "Edit"
      },
      {
        "hooks": [
          {
            "command": "workflow-runner hook pre-edit",
            "type": "command"
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "command": "workflow-runner hook pre-bash",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  }
}
